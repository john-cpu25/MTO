<Window x:Class="RincoMTO.Tools.DuplicateSheet.UI.SelectSheetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Sheets" Height="400" Width="300"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="0,0,0,10">
            <TabItem Header="Sheets">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Select Sheets to duplicate:" FontWeight="Bold" Margin="0,0,0,5"/>

                    <TextBox x:Name="TxtSearch" Grid.Row="1" Margin="0,0,0,5" Height="25" 
                             VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged" 
                             ToolTip="Search sheets..."/>

                    <ListBox x:Name="lbSheets" Grid.Row="2"
                             BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <StackPanel Margin="5">
                    <TextBlock Text="Target Sheet Series:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cboSheetSeries" IsEditable="True" ToolTip="Select or type a new Sheet Series" Height="25"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
            <Button x:Name="btnCheckAll" Content="All" Width="40" Height="25" Margin="0,0,5,0" Click="BtnCheckAll_Click"/>
            <Button x:Name="btnCheckNone" Content="None" Width="45" Height="25" Margin="0,0,10,0" Click="BtnCheckNone_Click"/>
            <Button x:Name="btnOk" Content="OK" Width="60" Height="25" Margin="0,0,5,0" Click="BtnOk_Click" IsDefault="True"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="60" Height="25" Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
