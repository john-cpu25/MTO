<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="RincoMTO Revit Add-in" 
           Manufacturer="NGUYEN" 
           Version="1.0.0.0" 
           UpgradeCode="7de3a968-3f5e-4b4d-96a8-a0ad8d8bd407"
           Scope="perUser">

    <ui:WixUI Id="WixUI_Minimal" />

    <Property Id="MSIINSTALLPERUSER" Value="1" />
    
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <WixVariable Id="WixUIDialogBmp" Value="Img/Background.png" />
    <WixVariable Id="WixUIBannerBmp" Value="Img/Logo.png" />

    <!-- Application Icon -->
    <Icon Id="icon.ico" SourceFile="Img/Logo.png" />
    <Property Id="ARPPRODUCTICON" Value="icon.ico" />

    <Feature Id="Main">
      <ComponentGroupRef Id="BundleComponentGroup" />
    </Feature>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="AutodeskDir" Name="Autodesk">
        <Directory Id="ApplicationPluginsDir" Name="ApplicationPlugins">
          <Directory Id="INSTALLFOLDER" Name="RincoMTO.bundle" />
        </Directory>
      </Directory>
    </StandardDirectory>

  </Package>

  <!-- Fragment for harvested files will be generated by the build script -->
</Wix>
